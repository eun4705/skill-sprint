{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagnosisResult",
  "type": "object",
  "required": [
    "summary", "target_role", "total_estimated_hours",
    "weekly_hours_available", "estimated_weeks_to_ready",
    "readiness_score", "skill_gaps", "curriculum", "motivational_note"
  ],
  "properties": {
    "summary":                   { "type": "string", "minLength": 30 },
    "target_role":               { "type": "string" },
    "total_estimated_hours":     { "type": "number", "minimum": 1 },
    "weekly_hours_available":    { "type": "number", "minimum": 0.5 },
    "estimated_weeks_to_ready":  { "type": "integer", "minimum": 1 },
    "readiness_score":           { "type": "number", "minimum": 0, "maximum": 100 },
    "motivational_note":         { "type": "string" },
    "skill_gaps": {
      "type": "array", "minItems": 3, "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["skill_name","severity","job_relevance","estimated_hours","reason"],
        "properties": {
          "skill_name":       { "type": "string" },
          "severity":         { "type": "number", "minimum": 1, "maximum": 10 },
          "job_relevance":    { "type": "number", "minimum": 1, "maximum": 10 },
          "estimated_hours":  { "type": "number", "minimum": 0.5 },
          "reason":           { "type": "string" }
        }
      }
    },
    "curriculum": {
      "type": "array", "minItems": 3, "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["order","title","skill_gap_addressed","learning_objective",
                     "estimated_minutes","search_query","difficulty"],
        "properties": {
          "order":                { "type": "integer", "minimum": 1 },
          "title":                { "type": "string" },
          "skill_gap_addressed":  { "type": "string" },
          "learning_objective":   { "type": "string" },
          "estimated_minutes":    { "type": "number", "minimum": 5 },
          "search_query":         { "type": "string" },
          "difficulty":           { "type": "string", "enum": ["beginner","intermediate","advanced"] }
        }
      }
    }
  }
}
